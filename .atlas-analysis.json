  "keyFeatures": [
    "Zero-config org scanning — connect once with a read-only token, no per-repo YAML required",
    "Cross-ecosystem dependency detection (Terraform, Docker, Python, CI/CD, Helm, Go, npm, Ansible, Kustomize, Kubernetes)",
    "Interactive dependency graph with Focus Mode, Impact Mode, clustering, and semantic zoom",
    "Impact analysis — BFS-powered blast radius query: 'If I change repo X, what else breaks?'",
    "Consumer-side artifact visibility — see every repo consuming a Terraform module, Docker image, or Helm chart and at which version",
    "Incremental scanning via last_activity_at to keep the graph fresh",
    "Multi-user workspaces with role-based access (owner / admin / member) and workspace API keys for CI",
    "Stripe-powered billing with free tier and paid plans"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register",
    "POST /api/v1/auth/login",
    "GET /api/v1/auth/me",
    "POST /api/v1/connected-orgs",
    "POST /api/v1/connected-orgs/{id}/scans",
    "GET /api/v1/connected-orgs/{id}/graph",
    "GET /api/v1/repositories/{id}/impact",
    "GET /api/v1/repositories/{id}/dependencies",
    "GET /api/v1/repositories/{id}/dependents",
    "GET /api/v1/artifacts/{id}/consumers",
    "GET /api/v1/artifacts/{id}/versions",
    "GET /api/v1/workspaces/{id}/api-keys",
    "POST /api/v1/workspaces/{id}/api-keys",
    "GET /api/v1/workspaces/{id}/billing",
    "GET /api/v1/workspaces/{id}/export"
  ]
